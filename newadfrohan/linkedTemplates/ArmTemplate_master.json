{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "newadfrohan"
		},
		"AzureDataLakeStorage_hospital_project_LS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage_hospital_project_LS'"
		},
		"LS_ADLS_Hospital_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_Hospital'"
		},
		"AzureDataLakeStorage_hospital_project_LS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://rohannewaccount1.dfs.core.windows.net/"
		},
		"AzureSQLServer_hospital_project_LS_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "projecthospitalserver.database.windows.net"
		},
		"AzureSQLServer_hospital_project_LS_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().db_name}"
		},
		"LS_ADLS_Hospital_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://rohannewaccount1.dfs.core.windows.net/"
		},
		"LS_AzureSQL_Hospital_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "projecthospitalserver.database.windows.net"
		},
		"LS_AzureSQL_Hospital_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().DatabaseName}"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "newadfrohan_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage_hospital_project_LS_accountKey": {
						"value": "[parameters('AzureDataLakeStorage_hospital_project_LS_accountKey')]"
					},
					"LS_ADLS_Hospital_accountKey": {
						"value": "[parameters('LS_ADLS_Hospital_accountKey')]"
					},
					"AzureDataLakeStorage_hospital_project_LS_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage_hospital_project_LS_properties_typeProperties_url')]"
					},
					"AzureSQLServer_hospital_project_LS_properties_typeProperties_server": {
						"value": "[parameters('AzureSQLServer_hospital_project_LS_properties_typeProperties_server')]"
					},
					"AzureSQLServer_hospital_project_LS_properties_typeProperties_database": {
						"value": "[parameters('AzureSQLServer_hospital_project_LS_properties_typeProperties_database')]"
					},
					"LS_ADLS_Hospital_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_Hospital_properties_typeProperties_url')]"
					},
					"LS_AzureSQL_Hospital_properties_typeProperties_server": {
						"value": "[parameters('LS_AzureSQL_Hospital_properties_typeProperties_server')]"
					},
					"LS_AzureSQL_Hospital_properties_typeProperties_database": {
						"value": "[parameters('LS_AzureSQL_Hospital_properties_typeProperties_database')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}