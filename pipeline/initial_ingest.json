{
	"name": "initial_ingest",
	"properties": {
		"activities": [
			{
				"name": "LookupMetaadata",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "SELECT TOP 1 * FROM dbo.ADF_Load_Metadata WHERE SourceName = '@{pipeline().parameters.SourceName}' AND Active = 1\n",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "AzureSQL_non_param",
						"type": "DatasetReference"
					},
					"firstRowOnly": false
				}
			}
		],
		"parameters": {
			"Sourcename": {
				"type": "string"
			}
		},
		"folder": {
			"name": "pipelines"
		},
		"annotations": []
	}
}